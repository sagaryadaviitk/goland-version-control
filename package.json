{
  "name": "goland-version-control",
  "displayName": "GoLand Version Control",
  "description": "A GoLand-inspired local changes, shelf, and stash workflow for Git changes in VS Code.",
  "version": "0.2.0",
  "publisher": "sagaryadaviitk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sagaryadaviitk/goland-version-control.git"
  },
  "homepage": "https://github.com/sagaryadaviitk/goland-version-control",
  "bugs": {
    "url": "https://github.com/sagaryadaviitk/goland-version-control/issues"
  },
  "main": "./dist/extension.js",
  "type": "commonjs",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "version-control",
    "goland",
    "jetbrains",
    "changes",
    "changelist",
    "diff"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:golandVersionControl.localChanges",
    "onView:golandVersionControl.shelf",
    "onView:golandVersionControl.stash",
    "onCommand:golandVersionControl.refresh",
    "onCommand:golandVersionControl.openDiff",
    "onCommand:golandVersionControl.nextChange",
    "onCommand:golandVersionControl.previousChange",
    "onCommand:golandVersionControl.shelve",
    "onCommand:golandVersionControl.saveToShelf",
    "onCommand:golandVersionControl.createStash"
  ],
  "files": [
    "dist/**",
    "resources/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "golandVersionControl",
          "title": "Version Control",
          "icon": "resources/version-control.svg"
        }
      ]
    },
    "views": {
      "golandVersionControl": [
        {
          "id": "golandVersionControl.localChanges",
          "name": "Local Changes",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "golandVersionControl.shelf",
          "name": "Shelf",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "golandVersionControl.stash",
          "name": "Stash",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "commands": [
      {
        "command": "golandVersionControl.refresh",
        "title": "GoLand Version Control: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "golandVersionControl.openDiff",
        "title": "GoLand Version Control: Open Diff",
        "icon": "$(diff)"
      },
      {
        "command": "golandVersionControl.openFile",
        "title": "GoLand Version Control: Open File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "golandVersionControl.nextChange",
        "title": "GoLand Version Control: Next Change",
        "icon": "$(arrow-down)"
      },
      {
        "command": "golandVersionControl.previousChange",
        "title": "GoLand Version Control: Previous Change",
        "icon": "$(arrow-up)"
      },
      {
        "command": "golandVersionControl.nextFile",
        "title": "GoLand Version Control: Next Changed File",
        "icon": "$(chevron-down)"
      },
      {
        "command": "golandVersionControl.previousFile",
        "title": "GoLand Version Control: Previous Changed File",
        "icon": "$(chevron-up)"
      },
      {
        "command": "golandVersionControl.stage",
        "title": "GoLand Version Control: Stage Selected",
        "icon": "$(add)"
      },
      {
        "command": "golandVersionControl.unstage",
        "title": "GoLand Version Control: Unstage Selected",
        "icon": "$(remove)"
      },
      {
        "command": "golandVersionControl.discard",
        "title": "GoLand Version Control: Discard Selected Changes",
        "icon": "$(discard)"
      },
      {
        "command": "golandVersionControl.revert",
        "title": "GoLand Version Control: Revert Changes",
        "icon": "$(discard)"
      },
      {
        "command": "golandVersionControl.createChangelist",
        "title": "GoLand Version Control: Create Changelist",
        "icon": "$(new-folder)"
      },
      {
        "command": "golandVersionControl.moveToChangelist",
        "title": "GoLand Version Control: Move to Changelist",
        "icon": "$(folder-active)"
      },
      {
        "command": "golandVersionControl.shelve",
        "title": "GoLand Version Control: Shelve Selected",
        "icon": "$(archive)"
      },
      {
        "command": "golandVersionControl.saveToShelf",
        "title": "GoLand Version Control: Save Selected to Shelf",
        "icon": "$(save)"
      },
      {
        "command": "golandVersionControl.unshelve",
        "title": "GoLand Version Control: Unshelve",
        "icon": "$(cloud-download)"
      },
      {
        "command": "golandVersionControl.restoreShelf",
        "title": "GoLand Version Control: Restore Shelf",
        "icon": "$(repo-pull)"
      },
      {
        "command": "golandVersionControl.deleteShelf",
        "title": "GoLand Version Control: Delete Shelf",
        "icon": "$(trash)"
      },
      {
        "command": "golandVersionControl.openShelfDiff",
        "title": "GoLand Version Control: Open Shelf Diff",
        "icon": "$(diff)"
      },
      {
        "command": "golandVersionControl.refreshShelf",
        "title": "GoLand Version Control: Refresh Shelf",
        "icon": "$(refresh)"
      },
      {
        "command": "golandVersionControl.createStash",
        "title": "GoLand Version Control: Create Stash",
        "icon": "$(repo-push)"
      },
      {
        "command": "golandVersionControl.applyStash",
        "title": "GoLand Version Control: Apply Stash",
        "icon": "$(repo-pull)"
      },
      {
        "command": "golandVersionControl.popStash",
        "title": "GoLand Version Control: Pop Stash",
        "icon": "$(cloud-download)"
      },
      {
        "command": "golandVersionControl.dropStash",
        "title": "GoLand Version Control: Drop Stash",
        "icon": "$(trash)"
      },
      {
        "command": "golandVersionControl.openStashDiff",
        "title": "GoLand Version Control: Open Stash Diff",
        "icon": "$(diff)"
      },
      {
        "command": "golandVersionControl.refreshStash",
        "title": "GoLand Version Control: Refresh Stash",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "golandVersionControl.refresh",
          "when": "view == golandVersionControl.localChanges",
          "group": "navigation@1"
        },
        {
          "command": "golandVersionControl.previousFile",
          "when": "view == golandVersionControl.localChanges",
          "group": "navigation@2"
        },
        {
          "command": "golandVersionControl.nextFile",
          "when": "view == golandVersionControl.localChanges",
          "group": "navigation@3"
        },
        {
          "command": "golandVersionControl.refreshShelf",
          "when": "view == golandVersionControl.shelf",
          "group": "navigation@1"
        },
        {
          "command": "golandVersionControl.createStash",
          "when": "view == golandVersionControl.stash",
          "group": "navigation@1"
        },
        {
          "command": "golandVersionControl.refreshStash",
          "when": "view == golandVersionControl.stash",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "golandVersionControl.openDiff",
          "when": "view == golandVersionControl.localChanges && viewItem =~ /change/",
          "group": "inline@1"
        },
        {
          "command": "golandVersionControl.stage",
          "when": "view == golandVersionControl.localChanges && viewItem =~ /stageable/",
          "group": "inline@2"
        },
        {
          "command": "golandVersionControl.unstage",
          "when": "view == golandVersionControl.localChanges && viewItem =~ /unstageable/",
          "group": "inline@2"
        },
        {
          "command": "golandVersionControl.revert",
          "when": "view == golandVersionControl.localChanges && viewItem =~ /discardable/",
          "group": "inline@3"
        },
        {
          "command": "golandVersionControl.openFile",
          "when": "view == golandVersionControl.localChanges && viewItem =~ /change/",
          "group": "navigation@1"
        },
        {
          "command": "golandVersionControl.shelve",
          "when": "view == golandVersionControl.localChanges && viewItem =~ /shelvable/",
          "group": "navigation@2"
        },
        {
          "command": "golandVersionControl.saveToShelf",
          "when": "view == golandVersionControl.localChanges && viewItem =~ /shelvable/",
          "group": "navigation@3"
        },
        {
          "command": "golandVersionControl.moveToChangelist",
          "when": "view == golandVersionControl.localChanges && viewItem =~ /change/",
          "group": "navigation@4"
        },
        {
          "command": "golandVersionControl.discard",
          "when": "view == golandVersionControl.localChanges && viewItem =~ /discardable/",
          "group": "navigation@5"
        },
        {
          "command": "golandVersionControl.openShelfDiff",
          "when": "view == golandVersionControl.shelf && viewItem == shelf",
          "group": "inline@1"
        },
        {
          "command": "golandVersionControl.unshelve",
          "when": "view == golandVersionControl.shelf && viewItem == shelf",
          "group": "inline@2"
        },
        {
          "command": "golandVersionControl.restoreShelf",
          "when": "view == golandVersionControl.shelf && viewItem == shelf",
          "group": "navigation@1"
        },
        {
          "command": "golandVersionControl.deleteShelf",
          "when": "view == golandVersionControl.shelf && viewItem == shelf",
          "group": "navigation@2"
        },
        {
          "command": "golandVersionControl.openStashDiff",
          "when": "view == golandVersionControl.stash && viewItem == stash",
          "group": "inline@1"
        },
        {
          "command": "golandVersionControl.applyStash",
          "when": "view == golandVersionControl.stash && viewItem == stash",
          "group": "inline@2"
        },
        {
          "command": "golandVersionControl.popStash",
          "when": "view == golandVersionControl.stash && viewItem == stash",
          "group": "navigation@1"
        },
        {
          "command": "golandVersionControl.dropStash",
          "when": "view == golandVersionControl.stash && viewItem == stash",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "golandVersionControl.openDiff"
        },
        {
          "command": "golandVersionControl.openFile"
        },
        {
          "command": "golandVersionControl.stage"
        },
        {
          "command": "golandVersionControl.unstage"
        },
        {
          "command": "golandVersionControl.discard"
        },
        {
          "command": "golandVersionControl.revert"
        },
        {
          "command": "golandVersionControl.createChangelist"
        },
        {
          "command": "golandVersionControl.moveToChangelist"
        },
        {
          "command": "golandVersionControl.shelve"
        },
        {
          "command": "golandVersionControl.saveToShelf"
        },
        {
          "command": "golandVersionControl.unshelve"
        },
        {
          "command": "golandVersionControl.restoreShelf"
        },
        {
          "command": "golandVersionControl.deleteShelf"
        },
        {
          "command": "golandVersionControl.openShelfDiff"
        },
        {
          "command": "golandVersionControl.refreshShelf"
        },
        {
          "command": "golandVersionControl.createStash"
        },
        {
          "command": "golandVersionControl.applyStash"
        },
        {
          "command": "golandVersionControl.popStash"
        },
        {
          "command": "golandVersionControl.dropStash"
        },
        {
          "command": "golandVersionControl.openStashDiff"
        },
        {
          "command": "golandVersionControl.refreshStash"
        }
      ]
    },
    "keybindings": [
      {
        "command": "golandVersionControl.nextFile",
        "key": "alt+down",
        "mac": "alt+down",
        "when": "focusedView == golandVersionControl.localChanges"
      },
      {
        "command": "golandVersionControl.previousFile",
        "key": "alt+up",
        "mac": "alt+up",
        "when": "focusedView == golandVersionControl.localChanges"
      }
    ],
    "configuration": {
      "title": "GoLand Version Control",
      "properties": {
        "golandVersionControl.showUntracked": {
          "type": "boolean",
          "default": false,
          "description": "Show untracked files in the GoLand Version Control local changes view."
        },
        "golandVersionControl.groupBy": {
          "type": "string",
          "default": "changelist",
          "enum": [
            "changelist",
            "status",
            "folder"
          ],
          "description": "Primary grouping mode for local changes."
        },
        "golandVersionControl.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh the local changes view when files or Git state change."
        },
        "golandVersionControl.confirmDiscard": {
          "type": "boolean",
          "default": false,
          "description": "Ask for confirmation before discarding local changes."
        },
        "golandVersionControl.debug": {
          "type": "boolean",
          "default": false,
          "description": "Write refresh and Git command timing to the GoLand Version Control output channel."
        },
        "golandVersionControl.openDiffAtFirstChange": {
          "type": "boolean",
          "default": true,
          "description": "Jump to the first changed hunk after opening a local change diff."
        },
        "golandVersionControl.shelfLocation": {
          "type": "string",
          "default": "",
          "description": "Optional absolute folder for extension-managed shelf patch storage. Empty uses VS Code workspace storage."
        },
        "golandVersionControl.stashIncludeUntracked": {
          "type": "boolean",
          "default": true,
          "description": "Include untracked files when creating Git stashes from the Stash view."
        },
        "golandVersionControl.compareBase": {
          "type": "string",
          "default": "HEAD",
          "enum": [
            "HEAD"
          ],
          "description": "Git revision used as the left side of local working-tree diffs."
        }
      }
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "compile": "npm run check-types && node esbuild.js",
    "compile:test": "tsc -p tsconfig.test.json",
    "package": "npm run compile",
    "test": "npm run test:unit",
    "test:unit": "npm run compile:test && node --test out/test/unit/*.test.js",
    "test:integration": "npm run compile:test && vscode-test",
    "vscode:prepublish": "npm run package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.10",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2"
  }
}
